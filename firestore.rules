rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to get user data safely. 
    // We use exists() to prevent rules from crashing if the profile is missing.
    function getUserData() {
      let profilePath = /databases/$(database)/documents/user_profiles/$(request.auth.uid);
      return exists(profilePath) ? get(profilePath).data : null;
    }

    function isMemberOfOrg(orgId) {
      let data = getUserData();
      return isSignedIn() && data != null && data.organizationId == orgId;
    }

    function isDocInMyOrg(docData) {
      let data = getUserData();
      return isSignedIn() && data != null && docData != null && data.organizationId == docData.organizationId;
    }

    match /organizations/{orgId} {
      allow get: if isMemberOfOrg(orgId);
      allow create: if isSignedIn();
      allow update: if isMemberOfOrg(orgId) && getUserData().role == 'admin';
    }

    match /user_profiles/{userId} {
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        (resource.data != null && getUserData() != null && getUserData().organizationId == resource.data.organizationId) ||
        (resource.data != null && resource.data.status == 'invited' && request.auth.token.email == resource.data.email)
      );

      // CRITICAL FIX: Allow users to list (query) their own profiles by email 
      // without needing an existing profile (essential for claiming invites).
      allow list: if isSignedIn() && (
        (request.auth.token.email != null && resource.data.email == request.auth.token.email) ||
        (getUserData() != null && resource.data.organizationId == getUserData().organizationId)
      );

      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == userId;

      allow delete: if isSignedIn() && (
        (resource.data.status == 'invited' && request.auth.token.email == request.auth.token.email) ||
        (getUserData() != null && getUserData().role == 'admin' && getUserData().organizationId == resource.data.organizationId)
      );
    }

    match /projects/{projectId} {
      allow get, list: if isSignedIn() && isDocInMyOrg(resource.data);
      allow create: if isSignedIn() && isDocInMyOrg(request.resource.data);
      allow update: if isSignedIn() && isDocInMyOrg(resource.data) && (getUserData().role in ['admin', 'manager']);
      allow delete: if isSignedIn() && isDocInMyOrg(resource.data) && getUserData().role == 'admin';
      
      match /milestones/{id} {
        allow list, get: if isSignedIn() && (isDocInMyOrg(resource.data) || isDocInMyOrg(get(/databases/$(database)/documents/projects/$(projectId)).data));
        allow create, update, delete: if isSignedIn() && (getUserData() != null && getUserData().role in ['admin', 'manager']);
      }
    }

    match /activities/{id} {
      allow list, get: if isSignedIn() && isDocInMyOrg(resource.data);
      allow create, update, delete: if isSignedIn() && isDocInMyOrg(request.resource.data || resource.data);
    }

    match /expenses/{id} {
      allow list, get: if isSignedIn() && isDocInMyOrg(resource.data);
      allow create, update, delete: if isSignedIn() && isDocInMyOrg(request.resource.data || resource.data);
    }

    match /documents/{id} {
      allow list, get: if isSignedIn() && isDocInMyOrg(resource.data);
      allow create: if isSignedIn() && isDocInMyOrg(request.resource.data) && (getUserData() != null && getUserData().role in ['admin', 'manager', 'officer']);
      allow delete: if isSignedIn() && isDocInMyOrg(resource.data) && (getUserData() != null && getUserData().role in ['admin', 'manager']);
    }

    match /notifications/{id} {
      // Simple, robust rule for personal notifications.
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }
  }
}