
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Authentication Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- Profile Fetcher ---
    function getMyProfile() {
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    // --- Tenant Isolation Helper ---
    function isMemberOf(orgId) {
      let profile = get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
      return profile != null && profile.organizationId == orgId;
    }

    // --- ORGANIZATIONS ---
    match /organizations/{orgId} {
      allow get: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || 
        isMemberOf(orgId)
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isMemberOf(orgId) && getMyProfile().role == 'admin';
    }

    // --- USER PROFILES ---
    match /user_profiles/{userId} {
      // Users can always read their own profile
      allow get: if isSignedIn() && request.auth.uid == userId;
      
      // Allow searching for invitation by email or if in same org
      allow list: if isSignedIn() && (
        resource.data.email == request.auth.token.email ||
        isMemberOf(resource.data.organizationId)
      );

      // Self creation or admin creation
      allow create: if isSignedIn() && (
        request.auth.uid == userId || 
        getMyProfile().role == 'admin'
      );

      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        (isMemberOf(resource.data.organizationId) && getMyProfile().role == 'admin')
      );
      
      // Allow deleting invited placeholder when claiming it
      allow delete: if isSignedIn() && (
        (resource.data.email == request.auth.token.email && resource.data.status == 'invited') ||
        (isMemberOf(resource.data.organizationId) && getMyProfile().role == 'admin')
      );
    }

    // --- PROJECTS ---
    match /projects/{projectId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.organizationId);
      allow create: if isSignedIn() && isMemberOf(request.resource.data.organizationId);
      allow update: if isSignedIn() && isMemberOf(resource.data.organizationId) && (getMyProfile().role in ['admin', 'manager']);
      allow delete: if isSignedIn() && isMemberOf(resource.data.organizationId) && (getMyProfile().role == 'admin');

      match /milestones/{id} {
        allow read: if isSignedIn() && isMemberOf(get(/databases/$(database)/documents/projects/$(projectId)).data.organizationId);
        allow write: if isSignedIn() && isMemberOf(get(/databases/$(database)/documents/projects/$(projectId)).data.organizationId) && (getMyProfile().role in ['admin', 'manager']);
      }
    }

    // --- ACTIVITIES ---
    match /activities/{id} {
      allow read: if isSignedIn() && isMemberOf(resource.data.organizationId);
      allow create: if isSignedIn() && isMemberOf(request.resource.data.organizationId);
      allow update, delete: if isSignedIn() && isMemberOf(resource.data.organizationId) && (getMyProfile().role in ['admin', 'manager', 'officer']);
    }

    // --- EXPENSES ---
    match /expenses/{id} {
      allow read: if isSignedIn() && isMemberOf(resource.data.organizationId);
      allow create: if isSignedIn() && isMemberOf(request.resource.data.organizationId);
      allow update, delete: if isSignedIn() && isMemberOf(resource.data.organizationId) && (getMyProfile().role in ['admin', 'manager', 'officer']);
    }

    // --- DOCUMENTS ---
    match /documents/{id} {
      allow read: if isSignedIn() && isMemberOf(resource.data.organizationId);
      allow create: if isSignedIn() && isMemberOf(request.resource.data.organizationId);
      allow update, delete: if isSignedIn() && isMemberOf(resource.data.organizationId) && (getMyProfile().role in ['admin', 'manager', 'officer']);
    }
  }
}
