
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    function isMemberOfOrg(orgId) {
      return isSignedIn() && getUserData().organizationId == orgId;
    }

    function isDocInMyOrg(docData) {
      return isSignedIn() && getUserData().organizationId == docData.organizationId;
    }

    match /organizations/{orgId} {
      allow get: if isMemberOfOrg(orgId);
      allow create: if isSignedIn(); // Allow creator to set up org
      allow update: if isMemberOfOrg(orgId) && getUserData().role == 'admin';
    }

    match /user_profiles/{userId} {
      // Allow listing profiles if they belong to the same organization
      // Allow get if it's the user's own profile or they are in the same organization
      allow list, get: if isSignedIn() && (request.auth.uid == userId || isDocInMyOrg(resource.data));
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == userId;
    }

    match /projects/{projectId} {
      allow list, get: if isSignedIn() && isDocInMyOrg(resource.data);
      allow create: if isSignedIn() && isDocInMyOrg(request.resource.data);
      allow update: if isSignedIn() && isDocInMyOrg(resource.data) && (getUserData().role in ['admin', 'manager']);
      allow delete: if isSignedIn() && isDocInMyOrg(resource.data) && getUserData().role == 'admin';
    }

    match /activities/{id} {
      allow list, get: if isSignedIn() && isDocInMyOrg(resource.data);
      allow create, update, delete: if isSignedIn() && isDocInMyOrg(request.resource.data || resource.data);
    }

    match /expenses/{id} {
      allow list, get: if isSignedIn() && isDocInMyOrg(resource.data);
      allow create, update, delete: if isSignedIn() && isDocInMyOrg(request.resource.data || resource.data);
    }
  }
}
