
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/user_profiles/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isMemberOfOrg(orgId) {
      let data = getUserData();
      return isSignedIn() && data != null && data.organizationId == orgId;
    }

    function isDocInMyOrg(docData) {
      let data = getUserData();
      return isSignedIn() && data != null && data.organizationId == docData.organizationId;
    }

    match /organizations/{orgId} {
      allow get: if isMemberOfOrg(orgId);
      allow create: if isSignedIn(); // Allow creator to set up org
      allow update: if isMemberOfOrg(orgId) && getUserData().role == 'admin';
    }

    match /user_profiles/{userId} {
      // Allow get if it's the user's own profile, or they are in the same organization
      // OR if they are an invited user checking their own invitation by email
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        isDocInMyOrg(resource.data) ||
        (resource.data.status == 'invited' && request.auth.token.email == resource.data.email)
      );

      // Allow listing profiles if they belong to the same organization
      // OR if the user is searching for their own invitation (filtered by email)
      allow list: if isSignedIn() && (
        isDocInMyOrg(resource.data) ||
        (request.auth.token.email != null && resource.data.email == request.auth.token.email)
      );

      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == userId;

      // Allow deleting an invitation record during the "claim" process
      // OR allow admins to remove staff
      allow delete: if isSignedIn() && (
        (resource.data.status == 'invited' && request.auth.token.email == resource.data.email) ||
        (getUserData().role == 'admin' && isDocInMyOrg(resource.data))
      );
    }

    match /projects/{projectId} {
      allow list, get: if isSignedIn() && isDocInMyOrg(resource.data);
      allow create: if isSignedIn() && isDocInMyOrg(request.resource.data);
      allow update: if isSignedIn() && isDocInMyOrg(resource.data) && (getUserData().role in ['admin', 'manager']);
      allow delete: if isSignedIn() && isDocInMyOrg(resource.data) && getUserData().role == 'admin';
    }

    match /activities/{id} {
      allow list, get: if isSignedIn() && isDocInMyOrg(resource.data);
      allow create, update, delete: if isSignedIn() && isDocInMyOrg(request.resource.data || resource.data);
    }

    match /expenses/{id} {
      allow list, get: if isSignedIn() && isDocInMyOrg(resource.data);
      allow create, update, delete: if isSignedIn() && isDocInMyOrg(request.resource.data || resource.data);
    }
  }
}
