rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to get user data safely. 
    function getUserData() {
      let profilePath = /databases/$(database)/documents/user_profiles/$(request.auth.uid);
      return exists(profilePath) ? get(profilePath).data : null;
    }

    function isMemberOfOrg(orgId) {
      let data = getUserData();
      return isSignedIn() && data != null && data.organizationId == orgId;
    }

    function isDocInMyOrg(docData) {
      let data = getUserData();
      return isSignedIn() && data != null && docData != null && data.organizationId == docData.organizationId;
    }

    match /organizations/{orgId} {
      allow get: if isSignedIn() && (isMemberOfOrg(orgId) || request.auth.uid == get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId);
      allow create: if isSignedIn();
      allow update: if isMemberOfOrg(orgId) && getUserData().role == 'admin';
    }

    match /user_profiles/{userId} {
      // 1. Allow a user to get their own profile by UID.
      allow get: if isSignedIn() && request.auth.uid == userId;
      
      // 2. Allow getting other profiles within the same organization.
      allow get: if isSignedIn() && getUserData() != null && get(/databases/$(database)/documents/user_profiles/$(userId)).data.organizationId == getUserData().organizationId;

      // 3. Allow listing (querying) profiles.
      // - Users can query for their own profile by email (essential for signup/login).
      // - Admins/Staff can query for profiles in their organization.
      allow list: if isSignedIn() && (
        (request.query.limit <= 10 && request.auth.token.email != null) ||
        (getUserData() != null)
      );

      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == userId;

      allow delete: if isSignedIn() && (
        (request.auth.uid == userId) ||
        // CRITICAL: Allow invited users to claim their profile by email match
        (resource.data.email == request.auth.token.email && resource.data.status == 'invited') ||
        (getUserData() != null && getUserData().role == 'admin' && get(/databases/$(database)/documents/user_profiles/$(userId)).data.organizationId == getUserData().organizationId)
      );
    }

    match /projects/{projectId} {
      allow list: if isSignedIn(); 
      allow get: if isSignedIn() && isDocInMyOrg(resource.data);
      allow create: if isSignedIn() && (request.resource.data.organizationId != null);
      allow update: if isSignedIn() && isDocInMyOrg(resource.data) && (getUserData().role in ['admin', 'manager']);
      allow delete: if isSignedIn() && isDocInMyOrg(resource.data) && getUserData().role == 'admin';
      
      match /milestones/{id} {
        allow list, get: if isSignedIn();
        allow create, update, delete: if isSignedIn() && (getUserData() != null && getUserData().role in ['admin', 'manager']);
      }
    }

    match /activities/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isDocInMyOrg(resource.data);
      allow create, update, delete: if isSignedIn();
    }

    match /expenses/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isDocInMyOrg(resource.data);
      allow create, update, delete: if isSignedIn();
    }

    match /documents/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isDocInMyOrg(resource.data);
      allow create: if isSignedIn() && (getUserData() != null && getUserData().role in ['admin', 'manager', 'officer']);
      allow delete: if isSignedIn() && isDocInMyOrg(resource.data) && (getUserData() != null && getUserData().role in ['admin', 'manager']);
    }

    match /notifications/{id} {
      // Users can only access notifications that belong to them.
      // We explicitly check the userId field for list/get operations.
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}